--- !u!114 &750574868
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 750574864}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 2c150a8ef466226498216c726083c3c5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::DialogueController
  dialoguePanel: {fileID: 750574866}
  textComponent: {fileID: 730500800}
  introLines:
  - "Hi, im your driving instructor for today. Before we head off, we\u2019ll go
    through a short route that you previously saw on the map. You will be able to
    access it at anytime at the top-left corner once we drive off. "
  - "But first \u2014 before any car moves \u2014 we need to make sure everything\u2019s
    in order."
  - "Take a look around the car and the documents you\u2019ve brought with you. Can
    you point out everything that\u2019s legally required for you to be driving today?"
  textSpeed: 0.03
  minigameIntroText: Click on all the necessary items and then press OK once everything
    is inspected.
  licenseText: "Good. You must always carry your learner permit when driving. It
    proves you\u2019re legally allowed to be on the road. If you\u2019re stopped
    and don\u2019t have it with you, you can be penalised."
  taxText: 'Those are your insurance and NCT discs. They show the vehicle is insured
    and has passed its roadworthiness test. '
  plateText: "Correct \u2014 your N/L-plates are displayed. They let other drivers
    know you\u2019re a novice and may need more time. They\u2019re required for the
    first two years after passing your test."
  inspectionsRemainingText: "Something\u2019s missing. Take another look \u2014 would
    you be allowed to drive without it?"
  wellDoneText: "Everything\u2019s in order. This is exactly the kind of check you
    should make before every drive."
  skipText: "Everything\u2019s in order. This is exactly the kind of check you should
    make before every drive."
  licenseButton: {fileID: 445228875}
  taxButton: {fileID: 2005332727}
  plateButton: {fileID: 885159284}
  okButton: {fileID: 2118903043}
  skipButton: {fileID: 2104048571}
  licenseImage: {fileID: 1449176903}
  taxImage: {fileID: 1402648917}
  plateImage: {fileID: 1677436382}
  panelManager: {fileID: 2131304566}
