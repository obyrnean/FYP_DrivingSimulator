  m_Script: {fileID: 11500000, guid: 201693d2fee3b5741a81f2c827d97b46, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::Scene5Controller
  textComponent: {fileID: 1784069943}
  dialoguePanel: {fileID: 161852896}
  textSpeed: 0.03
  delayBeforeDialogue: 1
  dialogueFadeDuration: 1.5
  optionButtons:
  - {fileID: 309406922}
  - {fileID: 212727744}
  - {fileID: 239295903}
  - {fileID: 1312788742}
  optionButtonTexts:
  - {fileID: 105524785}
  - {fileID: 1042865908}
  - {fileID: 725890340}
  - {fileID: 902869361}
  panelManager: {fileID: 2131304566}
  dialogueSteps:
  - line: "We\u2019re stopped at the junction now. Tell me \u2014 what are the most
      important things you need to check before turning right?"
    stepType: 1
    correctOptionIndex: 3
    feedbackCorrect: Correct. You must make sure all sort of traffic is clear in
      both directions.
    feedbackWrong: Not particularly. Your main focus here should be on the road ahead
      and all type of traffic, even non-road one such as cyclists and pedestrians.
    buttonTexts:
    - Only road, there's no pedestrian crossing
    - Check mirrors
    - Move off immediately
    - Check all sort of traffic from both sides
  - line: "So \u2014 when is it safe to turn right here?"
    stepType: 1
    correctOptionIndex: 2
    feedbackCorrect: "That\u2019s right. You only move when the road is clear and
      it\u2019s safe to complete the turn."
    feedbackWrong: "We\u2019ll keep working on that. The key at junctions is observation
      and patience."
    buttonTexts:
    - 'As soon as traffic from the right stops '
    - When pedestrians are crossing
    - "When there\u2019s a gap in traffic from both sides"
    - As soon as you signal
  - line: Good observation and patience. Junctions are one of the most common places
      for mistakes, so taking your time here is essential.
    stepType: 0
    correctOptionIndex: -1
    feedbackCorrect: 
    feedbackWrong: 
    buttonTexts: []
