  m_Script: {fileID: 11500000, guid: 799f88efffe00154faef3709d121d72a, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::Scene23Controller
  textComponent: {fileID: 2141472912}
  dialoguePanel: {fileID: 20155514}
  textSpeed: 0.03
  delayBeforeDialogue: 1
  dialogueFadeDuration: 1.5
  optionButtons:
  - {fileID: 292364875}
  - {fileID: 473713346}
  - {fileID: 1693543700}
  - {fileID: 1720511976}
  optionButtonTexts:
  - {fileID: 2124104049}
  - {fileID: 492732214}
  - {fileID: 246258972}
  - {fileID: 1473626213}
  panelManager: {fileID: 2131304566}
  dialogueSteps:
  - line: "We\u2019re about to join the motorway. What\u2019s the maximum speed limit
      here?"
    stepType: 1
    correctOptionIndex: 2
    feedbackCorrect: Correct. The maximum speed limit on Irish motorways is 120 kilometres
      per hour.
    feedbackWrong: Not quite. On Irish motorways, the maximum speed limit is 120
      kilometres per hour.
    buttonTexts:
    - 80 km/h
    - 100 km/h
    - 120 km/h
    - 140 km/h
  - line: "Now, that\u2019s the maximum speed \u2014 but when joining the motorway,
      what\u2019s the best speed to merge at?"
    stepType: 1
    correctOptionIndex: 2
    feedbackCorrect: "Well done. That\u2019s ideal. \tYou want to match the speed
      of motorway traffic as closely as possible, without exceeding the limit. Not
      too fast \u2014 so you stay in control \u2014 and not too slow, which would
      force other drivers to brake."
    feedbackWrong: "That\u2019s not ideal. Accelerating too quickly or even going
      too slowly reduces your and other driver's ability to react safely."
    buttonTexts:
    - 80 km/h
    - "Around 80\u2013100 km/h"
    - "Around 100\u2013110 km/h"
    - 120 km/h
