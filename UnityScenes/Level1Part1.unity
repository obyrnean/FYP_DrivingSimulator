  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::Scene36Controller
  textComponent: {fileID: 2136915572}
  dialoguePanel: {fileID: 1409089513}
  textSpeed: 0.03
  delayBeforeDialogue: 1
  dialogueFadeDuration: 1.5
  optionButtons:
  - {fileID: 1909172402}
  - {fileID: 712489161}
  - {fileID: 158296778}
  - {fileID: 1765744563}
  optionButtonTexts:
  - {fileID: 58770252}
  - {fileID: 1000665759}
  - {fileID: 1683595508}
  - {fileID: 1488803993}
  singleContinueButton: {fileID: 2059512054}
  singleContinueButtonText: {fileID: 1835502611}
  panelManager: {fileID: 2131304566}
  dialogueSteps:
  - line: "Alright, we\u2019re beside the pump. You\u2019re getting out to fill the
      tank. What\u2019s the first thing you check before doing anything else?"
    stepType: 1
    correctOptionIndex: 2
    feedbackCorrect: Correct. Always engine off before refuelling.
    feedbackWrong: Not yet. Engine off comes first.
    buttonTexts:
    - Start pumping fuel
    - Open the fuel cap
    - Turn off the engine
    - Go inside to pay
  - line: "Good. Engine\u2019s off. What do you do next?"
    stepType: 1
    correctOptionIndex: 1
    feedbackCorrect: Correct. Open the flap and remove the cap.
    feedbackWrong: "Not yet \u2014 you need access to the tank first."
    buttonTexts:
    - 'Pick up the nozzle '
    - Open the fuel flap and remove the cap
    - 'Go inside to pay '
    - Check tyre pressure
  - line: "Alright, cap\u2019s off. Before you pump, what should you check?"
    stepType: 1
    correctOptionIndex: 1
    feedbackCorrect: Correct. Always double-check fuel type.
    feedbackWrong: "Never assume. That\u2019s how cars get damaged and you should
      know before coming to get gas."
    buttonTexts:
    - Use whichever nozzle is closest
    - Check the fuel type on the pump and the car
    - 'Ask another driver '
    - "Guess \u2014 it\u2019ll be fine"
  - line: Off you go then. *Press on the machine to start*
    stepType: 2
    correctOptionIndex: 0
    feedbackCorrect: 
    feedbackWrong: 
    buttonTexts: []
