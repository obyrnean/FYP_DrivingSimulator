  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::Scene24Controller
  textComponent: {fileID: 995182373}
  dialoguePanel: {fileID: 1671527694}
  textSpeed: 0.03
  delayBeforeDialogue: 1
  dialogueFadeDuration: 1.5
  optionButtons:
  - {fileID: 1237466442}
  - {fileID: 1495823592}
  - {fileID: 1101188414}
  - {fileID: 635748999}
  optionButtonTexts:
  - {fileID: 509538468}
  - {fileID: 1515945418}
  - {fileID: 1497620062}
  - {fileID: 183644703}
  panelManager: {fileID: 2131304566}
  dialogueSteps:
  - line: Before we join, have a look at that yellow sign there. What does it mean?
    stepType: 3
    correctOptionIndex: 0
    correctOptionIndexes: 
    partialCorrectFeedback: 
    finalCorrectFeedback: 
    feedbackWrong: 
    buttonTexts: []
    imageOptions:
    - imageButton: {fileID: 1390634560}
      imageObject: {fileID: 1215736970}
      optionTexts:
      - Traffic joining from the left
      - Sharp left bend ahead
      - Lane ending
      - Motorway ahead
      correctOptionIndex: 0
      correctFeedback: "That\u2019s right. It\u2019s a warning sign for traffic joining
        from the left. It tells you to expect vehicles entering the road and to be
        prepared to adjust your speed or position."
      wrongFeedback: "Not quite. That sign warns of traffic joining from the left
        \u2014 it\u2019s there to prepare drivers for merging traffic."
  - line: Okay, now talk me through the steps you take when joining a motorway.
    stepType: 1
    correctOptionIndex: 1
    correctOptionIndexes: 
    partialCorrectFeedback: 
    finalCorrectFeedback: "Good. Always check your mirrors first, then signal, adjust
      your speed to match traffic, and merge when it\u2019s safe."
    feedbackWrong: "That order isn\u2019t safe. Mirrors always come first, then signal,
      then manoeuvre."
    buttonTexts:
    - "Signal \u2192 Move out \u2192 Check mirrors"
    - "Mirrors \u2192 Signal \u2192 Adjust speed \u2192 Merge when safe"
    - "Accelerate \u2192 Merge \u2192 Signal"
    - .
    imageOptions: []
