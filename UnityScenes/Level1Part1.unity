MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1960097612}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 289b0bdfe86fce54a9e8d9ff948d4a58, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::Scene27Controller
  textComponent: {fileID: 1151384121}
  dialoguePanel: {fileID: 1960097615}
  textSpeed: 0.03
  delayBeforeDialogue: 1
  dialogueFadeDuration: 1.5
  optionButtons:
  - {fileID: 305560378}
  - {fileID: 1506615617}
  - {fileID: 1797667761}
  optionButtonTexts:
  - {fileID: 1209516754}
  - {fileID: 52083543}
  - {fileID: 365990758}
  panelManager: {fileID: 2131304566}
  dialogueSteps:
  - line: "Alright, ahead of us there\u2019s a truck, and it\u2019s travelling slower
      than we are. Should we overtake it? And why?"
    stepType: 1
    correctOptionIndex: 1
    feedbackCorrect: "Correct. If a vehicle ahead is significantly slower, and it\u2019s
      safe, overtaking is the right choice. Sitting too close behind a truck reduces
      visibility and can increase risk."
    feedbackWrong: "No \u2014 overtaking isn\u2019t automatic, but it\u2019s absolutely
      allowed when safe. What matters is safety, visibility, and traffic flow, not
      the type of vehicle."
    buttonTexts:
    - 'Yes, because trucks should always be overtaken immediately '
    - "Yes, if it\u2019s safe, because it\u2019s slower and we don\u2019t want to
      sit too close behind it"
    - 'No, we should stay behind it no matter what '
  - line: "Okay, we\u2019re going to overtake the truck. Talk me through how you
      move into the right lane."
    stepType: 1
    correctOptionIndex: 2
    feedbackCorrect: "Very good. That\u2019s exactly right. \tMirrors first, then
      signal, confirm the truck is clearly visible in your mirror, \tand move across
      smoothly and calmly \u2014 no rushing, no sudden movements. And remember: never
      exceed the speed limit while overtaking."
    feedbackWrong: "No \u2014 that\u2019s dangerous. You must always check mirrors
      before moving, signal, and make sure the lane is clear."
    buttonTexts:
    - Signal and immediately pull out to right lane quickly
    - 'Check mirrors, speed-up and move into the right lane '
    - Check mirrors, signal, wait there's space, then move into lane
