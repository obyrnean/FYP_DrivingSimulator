MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1416403806}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: a00e5e98be78ba642b96fff0e6ad2ea1, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::Scene4Controller
  textComponent: {fileID: 298368566}
  dialoguePanel: {fileID: 1416403808}
  textSpeed: 0.03
  delayBeforeDialogue: 1
  dialogueFadeDuration: 1.5
  optionButtons:
  - {fileID: 1779826312}
  - {fileID: 829259586}
  - {fileID: 148706169}
  - {fileID: 726622469}
  optionButtonTexts:
  - {fileID: 179509768}
  - {fileID: 1635403109}
  - {fileID: 860952212}
  - {fileID: 2025988505}
  panelManager: {fileID: 2131304566}
  dialogueSteps:
  - line: "Alright, we\u2019re coming up to a T-junction and we\u2019re turning right.
      Let\u2019s slow things down and think carefully."
    stepType: 0
    correctOptionIndex: -1
    correctOptionIndexes: 
    partialCorrectFeedback: 
    finalCorrectFeedback: 
    feedbackWrong: 
    buttonTexts: []
    imageOptions: []
  - line: "Before we even get to the junction, take a look at the car in front. What\u2019s
      the correct following distance you should keep?"
    stepType: 1
    correctOptionIndex: 1
    correctOptionIndexes: 
    partialCorrectFeedback: 
    finalCorrectFeedback: Correct. You should keep at least a two-second gap from
      the vehicle in front. This gives you time to react if they stop suddenly.
    feedbackWrong: Not quite. You should keep at least a two-second gap from the
      vehicle in front. This gives you time to react if they stop suddenly.
    buttonTexts:
    - One car length
    - 'Two second gap '
    - 'As close as possible so traffic flows '
    - Five metres
    imageOptions: []
  - line: "Good. Now \u2014 would that distance change in different conditions, like
      rain or snow?"
    stepType: 1
    correctOptionIndex: 1
    correctOptionIndexes: 
    partialCorrectFeedback: 
    finalCorrectFeedback: Correct. In wet conditions, you should double your following
      distance to allow for longer stopping times.
    feedbackWrong: Not quite. In wet conditions, you should double your following
      distance to allow for longer stopping times.
    buttonTexts:
    - Stays the same
    - Double the distance in wet conditions
    - Reduce the distance to maintain control
    - Increase it slightly only at high speeds
    imageOptions: []
  - line: And what about in icy or snowy conditions?
    stepType: 1
    correctOptionIndex: 2
    correctOptionIndexes: 
    partialCorrectFeedback: 
    finalCorrectFeedback: Exactly. In icy or snowy conditions, stopping distances
      increase dramatically, so you may need up to ten times the normal following
      distance.
    feedbackWrong: Not really. In icy or snowy conditions, stopping distances increase
      dramatically, so you may need up to ten times the normal following distance.
    buttonTexts:
    - Keep the two-second rule
    - Triple the distance
    - "Increase it significantly \u2014 up to ten times the normal distance"
    - Follow closer to avoid skidding
    imageOptions: []
  - line: "Keeping a safe distance gives you time \u2014 and time gives you options.
      That\u2019s especially important near junctions."
    stepType: 0
    correctOptionIndex: -1
    correctOptionIndexes: 
    partialCorrectFeedback: 
    finalCorrectFeedback: 
    feedbackWrong: 
    buttonTexts: []
    imageOptions: []
  - line: As we approach here, take a look at the sign ahead. What does this sign
      mean?
    stepType: 3
    correctOptionIndex: 0
    correctOptionIndexes: 
    partialCorrectFeedback: 
    finalCorrectFeedback: 
    feedbackWrong: 
    buttonTexts: []
    imageOptions:
    - imageButton: {fileID: 2072738409}
      imageObject: {fileID: 1509421049}
      optionTexts:
      - School ahead / children crossing
      - Pedestrian crossing ahead
      - Playground nearby
      - Cycle lane ahead
      correctOptionIndex: 0
      correctFeedback: Excellent! You found them all.
      wrongFeedback: Not quite. This sign warns you that children may be crossing
        the road. Extra care is needed in this area.
  - line: Well done. Continue moving forward to the junction.
    stepType: 0
    correctOptionIndex: -1
    correctOptionIndexes: 
    partialCorrectFeedback: 
    finalCorrectFeedback: 
    feedbackWrong: 
    buttonTexts: []
    imageOptions: []
