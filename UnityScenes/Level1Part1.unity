  panelManager: {fileID: 2131304566}
  dialogueSteps:
  - line: "We\u2019re approaching another T-junction and we\u2019ll be turning right."
    stepType: 0
    correctOptionIndex: -1
    feedbackCorrect: 
    feedbackWrong: 
    buttonTexts: []
  - line: "Watch that car coming from the left. They\u2019re cutting the corner \u2014
      what should you do?"
    stepType: 1
    correctOptionIndex: 2
    feedbackCorrect: "Correct. Even if you have priority, you should anticipate other
      drivers\u2019 mistakes and be ready to stop."
    feedbackWrong: Not best. Always keep a safe position and reduce speed instead.
    buttonTexts:
    - Continue driving as you have right of way
    - Sound the horn and keep moving
    - Slow down and be prepared to stop
    - Move closer to the centre line to avoid them
  - line: "Reducing speed gives you time and space to react safely. Because you can\u2019t
      assume other drivers will stay in their lane."
    stepType: 0
    correctOptionIndex: 0
    feedbackCorrect: 
    feedbackWrong: 
    buttonTexts: []
