  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::Scene38Controller
  textComponent: {fileID: 1291529609}
  dialoguePanel: {fileID: 1711305493}
  textSpeed: 0.03
  delayBeforeDialogue: 1
  dialogueFadeDuration: 1.5
  optionButtons:
  - {fileID: 1166431129}
  - {fileID: 560031247}
  - {fileID: 815824697}
  - {fileID: 148964538}
  optionButtonTexts:
  - {fileID: 1995234228}
  - {fileID: 564464181}
  - {fileID: 2080734179}
  - {fileID: 1261131768}
  panelManager: {fileID: 2131304566}
  dialogueSteps:
  - line: "Good. You\u2019ve got the correct nozzle. What\u2019s next?"
    stepType: 1
    correctOptionIndex: 0
    feedbackCorrect: Correct. Insert it fully so it sits securely.
    feedbackWrong: Incorrect. Always keep it properly inserted.
    buttonTexts:
    - Insert the nozzle fully into the tank
    - Hold it loosely near the opening
    - Start pumping before inserting it
    - Leave it resting against the car
  - line: The tank is filling now. What are you waiting for?
    stepType: 1
    correctOptionIndex: 2
    feedbackCorrect: Correct. The click tells you the tank is full.
    feedbackWrong: Not safe. Let the pump do its job nad remove when you hear the
      click.
    buttonTexts:
    - "Stop when you think it\u2019s full"
    - Shake the nozzle
    - Wait for the automatic click
    - Keep filling even after it clicks
  - line: "Good. It\u2019s finished. What do you do now?"
    stepType: 1
    correctOptionIndex: 3
    feedbackCorrect: Correct. Secure everything before going to pay and leaving.
    feedbackWrong: "No \u2014 always make sure everything is secure and pay before
      leaving."
    buttonTexts:
    - Leave the nozzle in the car
    - Get back in the car
    - Drive off to pay
    - Return the nozzle and close the flap
  - line: "Well done. That was a proper refuel \u2014 safe, calm, and correct. These
      steps should always be done in the same order. Next, we\u2019ll head inside
      to pay, then practice leaving the station safely."
    stepType: 0
    correctOptionIndex: 0
    feedbackCorrect: 
    feedbackWrong: 
    buttonTexts: []
