  m_Script: {fileID: 11500000, guid: 244e4ce292e18394b9ff8baf2ca5647f, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::Scene14Controller
  textComponent: {fileID: 1086348556}
  dialoguePanel: {fileID: 27239282}
  textSpeed: 0.03
  delayBeforeDialogue: 1
  dialogueFadeDuration: 1.5
  optionButtons:
  - {fileID: 1264786515}
  - {fileID: 811481101}
  - {fileID: 486065569}
  - {fileID: 705455786}
  optionButtonTexts:
  - {fileID: 292417496}
  - {fileID: 2033078488}
  - {fileID: 1452204950}
  - {fileID: 1881588}
  panelManager: {fileID: 2131304566}
  dialogueSteps:
  - line: "Alright, we\u2019re stopping at this red light. Notice the yellow box
      junction ahead. Let\u2019s talk about it \u2014 what does this mean and how
      should we approach it?"
    stepType: 0
    correctOptionIndex: -1
    correctOptionIndexes: 
    partialCorrectFeedback: 
    finalCorrectFeedback: 
    feedbackWrong: 
    buttonTexts: []
  - line: What is this?
    stepType: 1
    correctOptionIndex: 1
    correctOptionIndexes: 
    partialCorrectFeedback: 
    finalCorrectFeedback: Exactly. This is a yellow box junction. You must not enter
      unless your exit is clear.
    feedbackWrong: "Not quite. This is a yellow box junction \u2014 its purpose is
      to prevent gridlock. Never block it."
    buttonTexts:
    - A pedestrian crossing
    - A yellow box junction
    - A no-parking zone
    - A bus lane
  - line: How does it work?
    stepType: 1
    correctOptionIndex: 0
    correctOptionIndexes: 
    partialCorrectFeedback: 
    finalCorrectFeedback: "Right. Even if the light is green, don\u2019t enter the
      box unless there\u2019s space ahead."
    feedbackWrong: Not correct. You must only enter if your exit is clear. Blocking
      the junction can cause congestion or accidents.
    buttonTexts:
    - You can only enter if your exit is clear
    - You can enter anytime
    - Stop in it if the light is green
    - Enter and wait for traffic to move
  - line: What should you check before entering?
    stepType: 2
    correctOptionIndex: 3
    correctOptionIndexes: 000000000100000003000000
    partialCorrectFeedback: Good, there are more correct options.
    finalCorrectFeedback: Good. Always check that your exit is clear and watch for
      other road users before entering a yellow box.
    feedbackWrong: "STOP! Remember \u2014 you must only enter a yellow box if your
      exit is clear. Blocking it can cause accidents and congestion."
    buttonTexts:
    - Is there enough space to clear the junction?
    - Are pedestrians or cyclists crossing?
    - Just go if the light is green
    - Are other vehicles obeying the rules?
  - line: What should you do if the box is already full?
    stepType: 1
    correctOptionIndex: 1
    correctOptionIndexes: 
    partialCorrectFeedback: '-'
    finalCorrectFeedback: "Correct. You wait until the box is clear \u2014 that\u2019s
      how you avoid blocking traffic."
    feedbackWrong: You must only enter a yellow box if your exit is clear. Blocking
      it can cause accidents or congestion.
    buttonTexts:
    - Enter anyway
    - "Wait behind the box until it\u2019s clear"
    - Stop partially in the box
    - Honk and move forward
