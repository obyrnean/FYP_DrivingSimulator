  panelManager: {fileID: 2131304566}
  dialogueSteps:
  - line: "We\u2019re approaching a train crossing. What should you do when approaching
      a crossing like this, even if the lights are green?"
    stepType: 1
    correctOptionIndex: 0
    feedbackCorrect: "Well done. Even if the lights are green, you must always slow
      down, check both directions for trains, and be prepared to stop. Safety comes
      first \u2014 never assume it\u2019s clear."
    feedbackWrong: "STOP! Remember \u2014 approaching a train crossing always requires
      caution. Slow down, look both ways, and be ready to stop, even if the lights
      are green. Never take risks here!"
    buttonTexts:
    - Slow down, look both ways, and prepare to stop if necessary
    - Speed up and cross quickly
    - Ignore the crossing if lights are green
    - Honk and continue
