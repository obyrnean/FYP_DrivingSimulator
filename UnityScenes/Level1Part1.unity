  - {fileID: 444826147}
  panelManager: {fileID: 2131304566}
  dialogueSteps:
  - line: "Alright, we\u2019re coming up to a parking spot nbehind that car. I\u2019m
      signaling it\u2014what do you think, can we park here?"
    stepType: 1
    correctOptionIndex: 1
    feedbackCorrect: "Exactly! That\u2019s the right thinking. You should never park
      in front of entrances, driveways, or gates. Observing your surroundings and
      respecting private access is both safe and legal."
    feedbackWrong: "Not quite. Even if the space looks empty, it\u2019s next to a
      house entrance. Parking here could block access for residents and is usually
      illegal. Always consider access and legality, not just availability."
    buttonTexts:
    - Yes
    - No
  - line: Continue on.
    stepType: 0
    correctOptionIndex: 0
    feedbackCorrect: 
    feedbackWrong: 
    buttonTexts: []
