  m_Script: {fileID: 11500000, guid: e2955f2b44b30a14b96a72d66a2bcbbf, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::Scene35Controller
  textComponent: {fileID: 845948826}
  dialoguePanel: {fileID: 1836459001}
  textSpeed: 0.03
  delayBeforeDialogue: 1
  dialogueFadeDuration: 1.5
  optionButtons:
  - {fileID: 565689454}
  - {fileID: 687798135}
  - {fileID: 511745883}
  - {fileID: 2147274240}
  optionButtonTexts:
  - {fileID: 995597832}
  - {fileID: 829708164}
  - {fileID: 1271602733}
  - {fileID: 1968918540}
  panelManager: {fileID: 2131304566}
  dialogueSteps:
  - line: "Okay, we\u2019re at the gas station. Before you stop, here\u2019s a quick
      question: On Irish cars, where is the fuel filler cap usually located?"
    stepType: 1
    correctOptionIndex: 0
    feedbackCorrect: Correct! Most Irish cars have the fuel filler on the left. This
      will determine which side of the pump you should align with.
    feedbackWrong: Not quite. You need to know which side the filler cap is on so
      you can line up with the pump properly.
    buttonTexts:
    - On the left side of the car
    - On the right side of the car
    - In the rear middle of the car
    - "Anywhere\u2014it doesn\u2019t matter"
  - line: And how should you position your car at the pump to refuel properly?
    stepType: 1
    correctOptionIndex: 1
    feedbackCorrect: Correct! Pull forward enough so the cable reaches comfortably.
      It avoids stretching the hose and makes refueling safer.
    feedbackWrong: Incorrect. Proper slightly forward positioning is important for
      safety, convenience, and efficient use of space.
    buttonTexts:
    - Stop far back, avoiding the car in front to bump into us.
    - Stop slightly forward, so the fuel cable can reach the filler easily
    - Go very forward between two pump areas, leaving space behind the pump for another
      car
    - "Stop wherever, it doesn\u2019t matter"
  - line: Always check your fuel cap side before pulling in, pull forward enough
      so the hose can reach, and leave room for cars behind you. This keeps things
      safe and smooth.
    stepType: 0
    correctOptionIndex: 0
    feedbackCorrect: 
    feedbackWrong: 
    buttonTexts: []
