    correctOptionIndex: -1
    correctOptionIndexes: 
    partialCorrectFeedback: 
    finalCorrectFeedback: 
    feedbackWrong: 
    buttonTexts: []
    imageOptions:
    - imageButton: {fileID: 524677631}
      imageObject: {fileID: 1711874667}
      optionTexts:
      - Stop completely
      - Give way / yield
      - No entry
      - Speed up
      correctOptionIndex: 1
      correctFeedback: Correct. This sign tells you to give way, slow down and let
        other vehicles go first if necessary.
      wrongFeedback: Not quite. This is a give way sign, you need to yield to other
        traffic when required.
    - imageButton: {fileID: 623401849}
      imageObject: {fileID: 1956239814}
      optionTexts:
      - No entry
      - Stop
      - No right turn allowed
      - Give way
      correctOptionIndex: 2
      correctFeedback: Correct. This sign means you are not allowed to turn right
        at this junction.
      wrongFeedback: "Not correct. This is a no right turn sign \u2014 you must choose
        another direction."
    - imageButton: {fileID: 2131867042}
      imageObject: {fileID: 1085491721}
      optionTexts:
      - You can only go straight
      - You may turn right, even if the main light is red
      - You must stop
      - You can turn right but must yield
      correctOptionIndex: 1
      correctFeedback: Correct. The green arrow allows you to turn right safely.
        You still need to check for pedestrians and other road users, but you may
        proceed even if the main light for straight traffic is red.
      wrongFeedback: Not quite. The green arrow indicates you may turn right. Always
        be aware of other road users when doing so, but the arrow gives you the right
        to go.
