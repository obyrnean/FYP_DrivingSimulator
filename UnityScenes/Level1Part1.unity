  m_Script: {fileID: 11500000, guid: 086ba3e54981a694b8a2789a1d6257a2, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::Scene26Controller
  textComponent: {fileID: 1057608388}
  dialoguePanel: {fileID: 1744694504}
  textSpeed: 0.03
  delayBeforeDialogue: 1
  dialogueFadeDuration: 1.5
  optionButtons:
  - {fileID: 272181235}
  - {fileID: 1816567110}
  - {fileID: 781068689}
  optionButtonTexts:
  - {fileID: 1336190421}
  - {fileID: 1671008463}
  - {fileID: 870454382}
  panelManager: {fileID: 2131304566}
  dialogueSteps:
  - line: "Okay, we\u2019re now on the motorway. There are two lanes here. What does
      each lane mean?"
    stepType: 1
    correctOptionIndex: 0
    feedbackCorrect: Correct. The left lane is the normal driving lane. The right
      lane is used only for overtaking, then you return to the left.
    feedbackWrong: "That\u2019s incorrect. Even at the speed limit, you must keep
      left unless overtaking. Staying in the right lane unnecessarily is poor lane
      discipline."
    buttonTexts:
    - Left lane is the normal driving lane, right lane is for overtaking
    - Left lane is for slow vehicles only, right lane is the main lane
    - "You can stay in either lane as long as you\u2019re doing the speed limit"
  - line: So which lane should we be in right now?
    stepType: 1
    correctOptionIndex: 0
    feedbackCorrect: "Exactly. Stay in the left lane. Only move right to overtake,
      then return once it\u2019s safe."
    feedbackWrong: "Always remember \u2014 motorway driving is about lane discipline,
      not preference."
    buttonTexts:
    - "Left lane, unless we\u2019re overtaking"
    - Right lane to keep traffic flowing
    - Either lane, depending on preference
