  m_Script: {fileID: 11500000, guid: 9dabed8a38f4fe74db17b1b8e5406a55, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::Scene25Controller
  textComponent: {fileID: 1178415249}
  dialoguePanel: {fileID: 1334209466}
  textSpeed: 0.03
  delayBeforeDialogue: 1
  dialogueFadeDuration: 1.5
  optionButtons:
  - {fileID: 368077964}
  - {fileID: 1496977697}
  - {fileID: 106738554}
  optionButtonTexts:
  - {fileID: 1985265217}
  - {fileID: 463016170}
  - {fileID: 1546546677}
  panelManager: {fileID: 2131304566}
  dialogueSteps:
  - line: "We\u2019re on the slip road now. There're still These hatched markings
      separating the motorway Can we cross into the motorway yet?"
    stepType: 1
    correctOptionIndex: 1
    feedbackCorrect: "Correct. These markings separate traffic. You should normally
      avoid them, but you may cross if it\u2019s safe and needed \u2014 for example,
      when merging."
    feedbackWrong: "Not quite. You shouldn\u2019t normally enter them, but you may
      if it\u2019s safe and necessary."
    buttonTexts:
    - Stay completely out of them at all times
    - Avoid driving over them unless it is safe and necessary
    - Drive over them immediately to join the motorway
  - line: "Now , if continuing to go at the same speed as that car \u2014 who has
      right of way here?"
    stepType: 1
    correctOptionIndex: 2
    feedbackCorrect: "Good \u2014 motorway traffic has priority. Your job on the
      slip road is to match speed, find a gap, and merge safely."
    feedbackWrong: No. Traffic on the motorway always has right of way. Joining traffic
      must give way, even if the slip road is ending.
    buttonTexts:
    - Vehicles joining from the slip road
    - Whoever reaches the merge point first
    - Traffic already on the motorway
