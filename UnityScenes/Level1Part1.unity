  m_Script: {fileID: 11500000, guid: 84a6a1ba6f319c042b9a35a229065a16, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::Scene37Controller
  dialoguePanel: {fileID: 1684703980}
  textComponent: {fileID: 1983030762}
  introLines:
  - Let's look into these parts you'll encounter when getting gas.
  textSpeed: 0.03
  minigameIntroText: ' *Press to get explanations of each sections* '
  feedback1: "This is the pump number. If you\u2019re paying inside, this is the
    number you give at the counter. Always remember it before walking away from the
    car."
  feedback2: "This screen shows two things while you\u2019re refuelling. The euro
    amount is how much fuel you\u2019ve paid for, and the litres show how much fuel
    has gone into the car. As one goes up, so does the other. You don\u2019t need
    to stop it yourself \u2014 the pump will stop automatically when the tank is
    full."
  feedback3: "This station allows pay-at-pump. That means you tap your card here
    before filling. Some stations work the other way around \u2014 you fill first,
    then go inside to pay. Always check the screen or signs on the pump to know which
    one applies."
  feedback4: If the car is diesel, this is the nozzle you use. Petrol cars must never
    use this.
  feedback5: Some stations offer more than one diesel nozzle, but diesel is diesel.
    Branding may differ.
  feedback6: "This is premium petrol. Only use it if the manufacturer recommends
    it. It\u2019s not required for most cars."
  feedback7: This is the one most petrol cars use. If your car takes petrol, this
    is usually the correct choice.
  inspectionsRemainingText: Still some inspection left to do.
  outroText: Well done! All properly inspected.
  skipText: Alright, let's move on to next steps.
  button1: {fileID: 1110665496}
  button2: {fileID: 1732487919}
  button3: {fileID: 240358193}
  button4: {fileID: 1778100699}
  button5: {fileID: 256201227}
  button6: {fileID: 1899170123}
  button7: {fileID: 340684851}
  okButton: {fileID: 21815949}
  skipButton: {fileID: 1990268206}
  panelManager: {fileID: 2131304566}
