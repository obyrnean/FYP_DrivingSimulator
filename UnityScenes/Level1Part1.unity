  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::Scene3Controller
  textComponent: {fileID: 1380246100}
  dialoguePanel: {fileID: 232548974}
  introLines:
  - "Alright, we\u2019re parked up and ready to move off. Talk me through what you\u2019ll
    do \u2014 step by step."
  textSpeed: 0.03
  delayBeforeDialogue: 2
  dialogueFadeDuration: 1
  stepButtons:
  - {fileID: 982670986}
  - {fileID: 1404836744}
  - {fileID: 1892462484}
  - {fileID: 1994599935}
  - {fileID: 1790992640}
  - {fileID: 1159514599}
  - {fileID: 234947863}
  - {fileID: 239230905}
  stepFeedback:
  - Good. You should always secure your seatbelt before moving.
  - "That\u2019s right. Proper mirror positioning gives you full awareness around
    the car."
  - Correct. The car needs to be running before selecting anything.
  - Good. Selecting the correct gear prepares the car to move.
  - "That\u2019s essential. Checking mirrors, windows, and blind spots ensures it\u2019s
    safe to move off."
  - "Correct. You\u2019re letting other road users know your intention."
  - Good. Releasing the handbrake allows the car to move safely.
  - And off we go!
  wrongStepText: You may have missed a step!
  allDoneText: "All steps well followed, well done. That was a safe and controlled
    move-off. Let\u2019s get going."
  panelManager: {fileID: 2131304566}
