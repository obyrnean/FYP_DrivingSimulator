  panelManager: {fileID: 2131304566}
  dialogueSteps:
  - line: "Alright, we\u2019re coming up on a gas station on the left. Let\u2019s
      practice turning in and stopping at a pump."
    stepType: 1
    correctOptionIndex: 1
    feedbackCorrect: "Good! That\u2019s the correct approach. Signaling and slowing
      down lets everyone know your intentions and keeps it safe."
    feedbackWrong: "Woah! Speed control and awareness are crucial. Don\u2019t try
      to rush across other vehicles, especially without signalling."
    buttonTexts:
    - Turn left immediately, no need to signal here
    - Slow down, signal left, check mirrors, then turn when clear
    - Stop, signal and turn left into the station.
    - Keep speed the same and cut in across traffic entering the station
